<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_inventory_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/inventory"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/manrope_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_product_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 Products"
        android:textColor="@color/outline"
        android:textSize="13sp"
        android:fontFamily="@font/inter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_inventory_title" />

    <!-- Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_search"
        style="@style/Widget.Material3.TextInputLayout.FilledBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/search_products"
        app:boxBackgroundColor="@color/surface_container_highest"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/primary_fixed_dim"
        app:hintTextColor="@color/outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_product_count">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:inputType="text"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Category Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/hsv_chips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/til_search">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="All"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_electronics"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Electronics"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_food"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_clothing"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clothing"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_other"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Other"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Summary Row -->
    <LinearLayout
        android:id="@+id/layout_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/hsv_chips">

        <TextView
            android:id="@+id/tv_in_stock_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_badge_success"
            android:text="0 In Stock"
            android:textColor="@color/on_secondary_fixed"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium" />

        <TextView
            android:id="@+id/tv_low_stock_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_badge_warning"
            android:text="0 Low Stock"
            android:textColor="@color/on_tertiary_fixed"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium" />

        <TextView
            android:id="@+id/tv_out_of_stock_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_error"
            android:text="0 Out of Stock"
            android:textColor="@color/on_error_container"
            android:textSize="12sp"
            android:fontFamily="@font/inter_medium" />
    </LinearLayout>

    <!-- Product RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_products"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_summary" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_products"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_summary">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/primary_fixed_dim" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/no_products_found"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:fontFamily="@font/manrope_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
