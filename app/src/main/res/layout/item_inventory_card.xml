<?xml version="1.0" encoding="utf-8"?>
<!-- L2 — ConstraintLayout with Guidelines + Barrier + Chain -->
<!-- Barrier prevents stock badge from overlapping product name -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_surface_low"
    android:padding="12dp">

    <!-- Product thumbnail placeholder -->
    <View
        android:id="@+id/iv_product_thumb"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_product_placeholder"
        android:layout_marginEnd="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Guideline at 60% width to constrain badge -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.60" />

    <!-- Product name — constrained between thumb and Barrier -->
    <TextView
        android:id="@+id/tv_product_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/colorTextPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="Product Name"
        app:layout_constraintStart_toEndOf="@+id/iv_product_thumb"
        app:layout_constraintEnd_toStartOf="@+id/tv_stock_badge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_chainStyle="spread_inside" />

    <!-- Category -->
    <TextView
        android:id="@+id/tv_product_category"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:text="Category"
        app:layout_constraintStart_toEndOf="@+id/iv_product_thumb"
        app:layout_constraintEnd_toStartOf="@+id/tv_stock_badge"
        app:layout_constraintTop_toBottomOf="@+id/tv_product_name" />

    <!-- Price -->
    <TextView
        android:id="@+id/tv_product_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/colorTextPrimary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:text="$0.00"
        app:layout_constraintStart_toEndOf="@+id/iv_product_thumb"
        app:layout_constraintEnd_toStartOf="@+id/tv_stock_badge"
        app:layout_constraintTop_toBottomOf="@+id/tv_product_category" />

    <!-- L2 — Barrier: prevents badge from overlapping name column -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="tv_product_name,tv_product_category,tv_product_price" />

    <!-- Stock Badge — constrained to end of parent, center vertical -->
    <TextView
        android:id="@+id/tv_stock_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_ok"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="STOCK: 0"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
