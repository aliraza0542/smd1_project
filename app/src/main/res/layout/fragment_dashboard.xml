<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- SECTION 1: HERO KPI BENTO GRID -->

        <!-- Card A: Total Sales (full width hero) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient"
            android:minHeight="160dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_sales"
                    android:textColor="@color/on_primary_container"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_success"
                    android:text="+12.5%"
                    android:textColor="@color/on_secondary_fixed"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_total_sales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Rs. 0"
                android:textColor="@color/on_primary"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold" />

            <TextView
                android:id="@+id/tv_sales_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Updated just now"
                android:textColor="@color/on_primary_container"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />
        </LinearLayout>

        <!-- Card B and C: row of 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- Card B: Today's Profit -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/todays_profit"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/tv_today_profit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Rs. 0"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑ 8% Daily Growth"
                        android:textColor="@color/on_secondary_container"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Card C: Total Items -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_items"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter" />

                <TextView
                    android:id="@+id/tv_total_items"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textColor="@color/on_surface"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_bold" />

                <TextView
                    android:id="@+id/tv_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Across 0 Categories"
                    android:textColor="@color/outline"
                    android:textSize="10sp"
                    android:fontFamily="@font/inter" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION 2: LOW STOCK ALERT BANNER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_badge_warning"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_alert_icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/low_stock_alerts"
                    android:textColor="@color/on_tertiary_fixed"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_bold" />

                <TextView
                    android:id="@+id/tv_alert_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="0 items require immediate restock"
                    android:textColor="@color/on_tertiary_fixed"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_view_alerts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_tertiary"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/view_list"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_medium" />
        </LinearLayout>

        <!-- SECTION 3: RECENT TRANSACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_section_container"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/recent_transactions"
                    android:textColor="@color/on_surface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- SECTION 4: QUICK ACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_actions"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold" />

            <LinearLayout
                android:id="@+id/btn_add_product"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_primary"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="8dp"
                    android:text="@string/add_product"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_new_sale"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_badge_success"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="8dp"
                    android:text="@string/new_sale"
                    android:textColor="@color/on_secondary_container"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_print_reports"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_tertiary"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="8dp"
                    android:text="@string/print_reports"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_medium" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
