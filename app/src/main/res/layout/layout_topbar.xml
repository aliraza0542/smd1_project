<?xml version="1.0" encoding="utf-8"?>
<!-- L5 — FrameLayout: notification badge stacked on bell icon -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/colorBackground"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <!-- Avatar + App name -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_gravity="start|center_vertical">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_avatar"
            android:contentDescription="User avatar" />

        <TextView
            android:id="@+id/tv_topbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/app_name"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- L5 — Bell icon with red notification badge stacked in FrameLayout -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="end|center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_bell"
            android:contentDescription="Notifications" />

        <!-- Red notification dot stacked on top-right of bell icon -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="top|end"
            android:background="@drawable/ic_badge_dot" />

    </FrameLayout>

</FrameLayout>
