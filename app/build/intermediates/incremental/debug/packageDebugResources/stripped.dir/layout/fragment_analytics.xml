<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/analytics"
            android:textColor="@color/on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_bold" />

        <!-- Date Range Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_from_date"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="From: Select"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                app:backgroundTint="@color/surface_container_low"
                app:cornerRadius="100dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_to_date"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="To: Select"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                app:backgroundTint="@color/surface_container_low"
                app:cornerRadius="100dp" />
        </LinearLayout>

        <!-- Report Type Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_report_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_sales_summary"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Sales Summary"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_profit_report"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profit Report"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_stock_report"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock Report"
                android:fontFamily="@font/inter"
                app:chipBackgroundColor="@color/chip_bg_color"
                app:chipCornerRadius="100dp" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Generate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate_report"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/generate_report"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_medium"
            app:backgroundTint="@null"
            app:cornerRadius="100dp" />

        <!-- Report Output -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:maxHeight="400dp">

            <TextView
                android:id="@+id/tv_report_output"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:fontFamily="monospace"
                android:minHeight="200dp"
                android:padding="16dp"
                android:text="@string/report_placeholder"
                android:textColor="@color/on_surface"
                android:textSize="13sp" />
        </ScrollView>

        <!-- Share Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_report"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="@string/share_report"
            android:textAllCaps="false"
            android:textColor="@color/on_secondary_container"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_medium"
            android:visibility="gone"
            app:backgroundTint="@color/secondary_container"
            app:cornerRadius="100dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
