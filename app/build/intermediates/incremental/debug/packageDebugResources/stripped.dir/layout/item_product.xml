<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Row 1: Name + Category -->
        <TextView
            android:id="@+id/tv_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Product Name"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_bold"
            app:layout_constraintEnd_toStartOf="@+id/tv_category_badge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_category_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_category_badge"
            android:text="Category"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            android:fontFamily="@font/inter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Row 2: Prices -->
        <TextView
            android:id="@+id/tv_purchase_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Purchase: Rs.0"
            android:textColor="@color/outline"
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_product_name" />

        <TextView
            android:id="@+id/tv_selling_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:text="Selling: Rs.0"
            android:textColor="@color/on_secondary_container"
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            app:layout_constraintStart_toEndOf="@+id/tv_purchase_price"
            app:layout_constraintTop_toBottomOf="@+id/tv_product_name" />

        <!-- Row 3: Stock + Status Badge -->
        <TextView
            android:id="@+id/tv_stock_qty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawablePadding="4dp"
            android:text="0 units"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_purchase_price" />

        <TextView
            android:id="@+id/badge_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_badge_success"
            android:text="IN STOCK"
            android:textColor="@color/on_secondary_fixed"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_selling_price" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
