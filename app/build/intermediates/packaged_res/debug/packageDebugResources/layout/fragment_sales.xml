<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_pos_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/point_of_sale"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/manrope_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_pos_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/record_new_transactions"
        android:textColor="@color/outline"
        android:textSize="13sp"
        android:fontFamily="@font/inter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pos_title" />

    <!-- Summary Cards Row -->
    <LinearLayout
        android:id="@+id/layout_sales_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pos_subtitle">

        <!-- Today's Sales -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/todays_sales"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/tv_today_sales_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rs. 0"
                android:textColor="@color/on_secondary_container"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold" />
        </LinearLayout>

        <!-- Today's Profit -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/todays_profit"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/tv_today_profit_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rs. 0"
                android:textColor="@color/secondary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold" />
        </LinearLayout>

        <!-- Transactions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/transactions"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:fontFamily="@font/inter" />

            <TextView
                android:id="@+id/tv_transactions_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Sales RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_sales"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_sales_summary" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_sales"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_sales_summary">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/primary_fixed_dim" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/no_sales_yet"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:fontFamily="@font/manrope_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
